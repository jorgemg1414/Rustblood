{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vue",
  "builds": [
    {
      "src": "backend/api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/gallery",
      "dest": "/backend/api/gallery.js"
    },
    {
      "src": "/api/gallery/:id",
      "dest": "/backend/api/gallery.js"
    },
    {
      "src": "/api/posts",
      "dest": "/backend/api/posts.js"
    },
    {
      "src": "/api/posts/:id",
      "dest": "/backend/api/posts.js"
    },
    {
      "src": "/api/messages",
      "dest": "/backend/api/messages.js"
    },
    {
      "src": "/api/messages/:id",
      "dest": "/backend/api/messages.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/frontend/dist/index.html" }
  ],
  "env": {
    "SUPABASE_URL": "@supabase-url",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase-service-role-key"
  }
}
