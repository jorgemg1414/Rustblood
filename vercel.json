{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vue",

  "routes": [
    { "src": "/api/gallery", "dest": "/backend/api/gallery.js" },
    { "src": "/api/gallery/:id", "dest": "/backend/api/gallery.js" },
    { "src": "/api/posts", "dest": "/backend/api/posts.js" },
    { "src": "/api/posts/:id", "dest": "/backend/api/posts.js" },
    { "src": "/api/messages", "dest": "/backend/api/messages.js" },
    { "src": "/api/messages/:id", "dest": "/backend/api/messages.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}
